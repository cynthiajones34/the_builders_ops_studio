{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "README.md",
      "CHANGELOG.md",
      "VERSION",
      "admin-portal/**",
      "functions/**",
      "functions-leadmagnet/**"
    ],
    "rewrites": [
      { "source": "/api/gmailAuthUrl", "function": { "functionId": "gmailAuthUrl", "region": "us-central1" } },
      { "source": "/api/gmailOauthCallback", "function": { "functionId": "gmailOauthCallback", "region": "us-central1" } },
      { "source": "/api/meetingPrep", "function": { "functionId": "meetingPrep", "region": "us-central1" } },
      { "source": "/api/fetchIntakeResponses", "function": { "functionId": "fetchIntakeResponses", "region": "us-central1" } },
      { "source": "/admin/**", "destination": "/admin/index.html" }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs22",
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
    },
    {
      "source": "functions-leadmagnet",
      "codebase": "leadmagnet",
      "runtime": "nodejs20"
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  }
}
