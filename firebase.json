{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "README.md",
      "CHANGELOG.md",
      "VERSION",
      "admin-portal/**",
      "functions/**"
    ],
    "rewrites": [
      { "source": "/api/askAdvisor", "function": { "functionId": "askAdvisor", "region": "us-central1" } },
      { "source": "/api/dailyBriefing", "function": { "functionId": "dailyBriefing", "region": "us-central1" } },
      { "source": "/api/findOpportunities", "function": { "functionId": "findOpportunities", "region": "us-central1" } },
      { "source": "/api/generateReport", "function": { "functionId": "generateReport", "region": "us-central1" } },
      { "source": "/api/generateProjects", "function": { "functionId": "generateProjects", "region": "us-central1" } },
      { "source": "/api/generateContent", "function": { "functionId": "generateContent", "region": "us-central1" } },
      { "source": "/api/draftContent", "function": { "functionId": "draftContent", "region": "us-central1" } },
      { "source": "/api/gmailAuthUrl", "function": { "functionId": "gmailAuthUrl", "region": "us-central1" } },
      { "source": "/api/gmailOauthCallback", "function": { "functionId": "gmailOauthCallback", "region": "us-central1" } },
      { "source": "/api/syncGmail", "function": { "functionId": "syncGmail", "region": "us-central1" } },
      { "source": "/api/syncMeetings", "function": { "functionId": "syncMeetings", "region": "us-central1" } },
      { "source": "/api/meetingPrep", "function": { "functionId": "meetingPrep", "region": "us-central1" } },
      { "source": "/api/fetchIntakeResponses", "function": { "functionId": "fetchIntakeResponses", "region": "us-central1" } },
      { "source": "/admin/**", "destination": "/admin/index.html" }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22",
    "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
