{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "README.md",
      "functions/**"
    ],
    "rewrites": [
      {
        "source": "/api/send-audit",
        "function": { "functionId": "sendAudit", "region": "us-central1" }
      }
    ]
  },
  "functions": {
    "source": "functions"
  }
}
