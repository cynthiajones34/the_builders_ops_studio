{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "README.md",
      "CHANGELOG.md",
      "VERSION",
      "admin-portal/**",
      "functions/**"
    ],
    "rewrites": [
      { "source": "/admin/**", "destination": "/admin/index.html" }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22",
    "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
  }
}
