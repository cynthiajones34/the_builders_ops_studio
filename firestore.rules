rules_version = '2';

// Command Center data layer. Everything is locked to the two authorized BOS
// accounts, and each account can only read its own tree. Cloud Functions use
// the Admin SDK, which bypasses these rules, so all writes (and the Gmail
// refresh token under /private) stay server-side only.
service cloud.firestore {
  match /databases/{database}/documents {

    function authorized() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'cynthia@thebuildersopsstudio.com',
          'cynthiajones34@gmail.com'
        ];
    }

    // Categorized inbox, written by the syncGmail function.
    match /users/{uid}/emails/{doc} {
      allow read: if authorized() && request.auth.uid == uid;
    }

    // Meeting readouts, written by the syncMeetings function.
    match /users/{uid}/meetings/{doc} {
      allow read: if authorized() && request.auth.uid == uid;
    }

    // Opportunities, written by the findOpportunities function.
    match /users/{uid}/opportunities/{doc} {
      allow read: if authorized() && request.auth.uid == uid;
    }

    // Knowledge Base resources, added by the owner from the client.
    match /users/{uid}/knowledge/{doc} {
      allow read, create, update, delete: if authorized() && request.auth.uid == uid;
    }

    // Lightweight UI state (e.g. checked-off priorities), owned by the user.
    match /users/{uid}/state/{doc} {
      allow read, write: if authorized() && request.auth.uid == uid;
    }

    // Connection + last-sync state the UI reads to know if Gmail is linked.
    match /users/{uid}/meta/{doc} {
      allow read: if authorized() && request.auth.uid == uid;
    }

    // Refresh tokens (users/{uid}/private/**), oauthStates/**, and anything
    // else default to deny for clients: no rule grants access.
  }
}
